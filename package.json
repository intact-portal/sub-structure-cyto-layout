{
  "name": "cytoscape-layout-plugin",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp src/index.html dist/index.html && cp node_modules/cytoscape/dist/cytoscape.min.js dist/ && cp -r data dist/data",
    "dev": "npm run build && concurrently \"tsc --watch\" \"http-server dist -p 8080 -c-1\"",
    "deploy": "npm run build && gh-pages -d dist -t"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "concurrently": "^9.2.1",
    "cytoscape": "^3.33.1",
    "gh-pages": "^6.3.0",
    "http-server": "^14.1.1",
    "typescript": "^5.9.3",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "private": true,
  "keywords": [],
